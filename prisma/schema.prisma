// Central / root database schema — stores the tenant registry.
// Each tenant gets its own Postgres database; this DB tracks them.

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/root-client"
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id               String   @id @default(cuid())
  name             String   @unique
  connectionString String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

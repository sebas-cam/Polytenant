// Per-tenant database schema. Each tenant DB has this shape.
// `prisma migrate deploy` is run against every tenant DB on creation / on sync.

generator client {
  provider = "prisma-client-js"
  output   = "../../node_modules/.prisma/tenant-client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Singleton-style: exactly one row per tenant DB, id = "singleton".
// Used to render the tenant's public landing page on its subdomain.
model TenantSettings {
  id             String   @id @default("singleton")
  primaryColor   String   @default("#0f172a")
  secondaryColor String   @default("#f8fafc")
  headline       String   @default("Welcome")
  description    String   @default("This is your tenant landing page.")
  updatedAt      DateTime @updatedAt
}
